# StockTracker application environment variables

# Alpha Vantage API Key (免费，额度: 5次/分钟, 500次/天)
# 注册地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=YOUR_API_KEY_HERE
# 兼容旧配置（可选，不推荐）
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=

# 中国节假日 API Key（可选）
# - 用于 A 股 / 基金交易日判断；未配置时使用匿名额度
# - 注册地址: https://www.jiejiariapi.com/
JIEJIARI_API_KEY=

# AI 模型配置（推荐放在 .env.local，避免密钥进入 SQLite / JSON 备份）
# AI_PROVIDER:
# - openai-compatible：OpenAI Chat Completions 兼容接口，例如 OpenAI、DeepSeek、Qwen、OpenRouter、部分本地网关
# - anthropic-compatible：Anthropic Messages 兼容接口，例如 Claude API 或兼容网关
AI_PROVIDER=openai-compatible

# AI_BASE_URL:
# - openai-compatible 示例：https://api.openai.com/v1
# - anthropic-compatible 示例：https://api.anthropic.com/v1
# - 也可以填写兼容服务商或本地网关地址，例如 http://localhost:11434/v1
AI_BASE_URL=https://api.openai.com/v1

# AI_MODEL:
# - 模型名称由服务商决定，例如 gpt-4.1-mini、deepseek-chat、qwen-plus、claude-3-5-sonnet-latest
AI_MODEL=

# AI_API_KEY:
# - 服务端使用，不会暴露给浏览器；真实密钥请只写在 .env.local
AI_API_KEY=

# AI_EMBEDDING_BASE_URL（可选，财报 RAG 检索用）:
# - 财报 RAG 的向量检索需要 openai-compatible 的 embeddings 接口。
# - 留空时默认复用 AI_BASE_URL（多数服务商 chat 与 embeddings 同源，开箱即用）。
# - 仅当你的 chat 端点不提供 /embeddings、或想用单独的 embedding 服务时才需配置。
# - 注意：anthropic-compatible 不提供 embeddings，此时必须在这里指定一个 openai-compatible 端点，否则 RAG 自动降级为截断模式。
AI_EMBEDDING_BASE_URL=

# AI_EMBEDDING_MODEL（可选，财报 RAG 检索用）:
# - embedding 模型名，例如 text-embedding-3-small、bge-m3、text-embedding-v3
# - 留空时默认 text-embedding-3-small
AI_EMBEDDING_MODEL=

# Agent Skill 扩展目录（可选）
# - 默认会读取 skills/custom
# - 如需额外挂载目录，可使用系统路径分隔符配置多个目录：
#   macOS/Linux 使用冒号，例如 /path/a:/path/b
#   Windows 使用分号，例如 C:\skills-a;D:\skills-b
# - 当前只加载 SKILL.md 元数据并绑定仓库内受控执行器，不会执行外部任意脚本
AGENT_SKILL_PATHS=

# SQLite 数据库路径（可选）
# - 本地开发默认使用 data/finance.sqlite
# - Docker 镜像默认使用 /app/data/finance.sqlite
FINANCE_SQLITE_PATH=

# 服务端日志级别（可选）
# - 可选值：debug / info / warn / error / silent
# - 开发态默认 debug，生产默认 info；排查外部 API 调用时可临时设为 debug
APP_LOG_LEVEL=

# 注意：
# 1. 本地 Next.js 开发时，将此文件复制为 .env.local
# 2. Docker 容器也会通过 docker/docker-compose.yml 可选读取 .env.local 并注入这些业务变量
# 3. Docker 编排配置请使用 docker/.env.example -> docker/.env
# 4. 从对应网站获取 API Key
# 5. 优先使用服务端变量 ALPHA_VANTAGE_API_KEY / AI_API_KEY / JIEJIARI_API_KEY，避免 Key 暴露到前端
