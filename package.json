{
  "name": "stocktracker",
  "version": "1.0.0",
  "description": "Local-first portfolio tracker and AI investing copilot.",
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "node scripts/only-pnpm.cjs",
    "prebuild": "node scripts/only-pnpm.cjs",
    "dev": "node scripts/dev.cjs",
    "lint": "tsc --noEmit",
    "build": "next build",
    "start": "next start -p 3218",
    "test": "tsx --test tests/**/*.test.ts",
    "test:external": "tsx --test tests/external-apis.test.ts"
  },
  "keywords": [
    "portfolio",
    "stock",
    "finance",
    "investment",
    "ai-agent",
    "nextjs",
    "sqlite"
  ],
  "author": "StockTracker contributors",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "0.3.79",
    "@langchain/openai": "0.6.13",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@uiw/react-json-view": "^2.0.0-alpha.42",
    "better-sqlite3": "^12.9.0",
    "big.js": "^7.0.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "iconv-lite": "^0.7.2",
    "lightweight-charts": "^4.2.3",
    "next": "^16.2.4",
    "pdf-parse": "1.1.1",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.3",
    "zod": "3.25.76",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.3.3",
    "@types/pdf-parse": "1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.12",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
