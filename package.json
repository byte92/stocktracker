{
  "name": "stocktracker",
  "version": "0.1.0",
  "description": "Local-first portfolio tracker and AI investing copilot.",
  "main": "electron/main.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "preinstall": "node scripts/only-pnpm.cjs",
    "prebuild": "node scripts/only-pnpm.cjs",
    "dev": "node scripts/dev.cjs",
    "lint": "tsc --noEmit",
    "build": "next build",
    "start": "next start -p 3218",
    "test": "tsx --test tests/**/*.test.ts",
    "test:external": "tsx --test tests/external-apis.test.ts",
    "electron:dev": "tsc -p electron/tsconfig.json && electron-rebuild -m .next/standalone && electron .",
    "electron:build": "pnpm build && tsc -p electron/tsconfig.json && electron-rebuild -m .next/standalone && electron-builder",
    "electron:build:mac": "pnpm build && tsc -p electron/tsconfig.json && electron-rebuild -m .next/standalone && electron-builder --mac",
    "electron:build:win": "pnpm build && tsc -p electron/tsconfig.json && electron-rebuild -m .next/standalone && electron-builder --win"
  },
  "keywords": [
    "portfolio",
    "stock",
    "finance",
    "investment",
    "ai-agent",
    "nextjs",
    "sqlite"
  ],
  "author": "StockTracker contributors",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "1.1.48",
    "@langchain/openai": "1.4.7",
    "@langchain/textsplitters": "^1.0.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@uiw/react-json-view": "2.0.0-alpha.43",
    "better-sqlite3": "^12.10.0",
    "big.js": "^7.0.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "iconv-lite": "^0.7.2",
    "lightweight-charts": "^4.2.3",
    "next": "^16.2.9",
    "pdf-parse": "1.1.1",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.9.0",
    "zod": "3.25.76",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "overrides": {
      "postcss": "$postcss"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/big.js": "^7.0.0",
    "@types/node": "^25.9.2",
    "@types/pdf-parse": "1.1.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.15",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
